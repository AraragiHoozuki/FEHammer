<Window
    x:Class="FEHagemu.Views.AboutWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:FEHagemu.ViewModels"
    Title="About FEHagemu"
    Width="520"
    Height="350"
    CanResize="False"
    Icon="/Assets/favicon.ico"
    WindowStartupLocation="CenterOwner"
    x:DataType="vm:AboutWindowViewModel"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border
            Padding="24,22"
            Background="{DynamicResource SemiColorBackground0}"
            BorderBrush="{DynamicResource SemiColorBorder}"
            BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="72,*">
                <Image
                    Width="56"
                    Height="56"
                    HorizontalAlignment="Left"
                    Source="/Assets/favicon.ico"
                    Stretch="Uniform" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="FEHagemu" />
                    <TextBlock
                        FontSize="13"
                        Foreground="{DynamicResource SemiColorText2}"
                        Text="火焰纹章英雄数据浏览与编辑器" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid
            Grid.Row="1"
            Margin="24,20"
            ColumnDefinitions="92,*"
            RowDefinitions="Auto,Auto,Auto">
            <TextBlock FontWeight="SemiBold" Text="版本" />
            <TextBlock Grid.Column="1" Text="{Binding VersionText}" />
            <TextBlock Grid.Row="1" Margin="0,14,0,0" FontWeight="SemiBold" Text="运行环境" />
            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,14,0,0" Text="{Binding RuntimeText}" />
            <TextBlock Grid.Row="2" Margin="0,14,0,0" FontWeight="SemiBold" Text="程序数据" />
            <TextBlock
                Grid.Row="2"
                Grid.Column="1"
                Margin="0,14,0,0"
                FontFamily="Consolas"
                FontSize="12"
                Text="{Binding ApplicationDataPath}"
                TextTrimming="CharacterEllipsis"
                ToolTip.Tip="{Binding ApplicationDataPath}" />
        </Grid>

        <Border
            Grid.Row="2"
            Padding="16,10"
            BorderBrush="{DynamicResource SemiColorBorder}"
            BorderThickness="0,1,0,0">
            <Button
                HorizontalAlignment="Right"
                MinWidth="88"
                Click="CloseButton_OnClick"
                Content="关闭" />
        </Border>
    </Grid>
</Window>
