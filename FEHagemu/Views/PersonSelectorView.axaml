<UserControl
    x:Class="FEHagemu.Views.PersonSelectorView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FEHagemu.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FEHagemu"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:views="clr-namespace:FEHagemu.Views"
    xmlns:vm="using:FEHagemu.ViewModels"
    xmlns:tools="using:FEHagemu.ViewModels.Tools"
    Name="PersonSelectorDialog"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    d:DesignHeight="600"
    d:DesignWidth="600"
    x:DataType="vm:PersonSelectorViewModel"
    mc:Ignorable="d">

    <UserControl.Styles>
        <!-- Filter toggle buttons -->
        <Style Selector="ToggleButton.filterBtn">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Opacity" Value="0.55" />
            <Setter Property="RenderTransform" Value="scale(0.95)" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.filterBtn:pointerover">
            <Setter Property="Opacity" Value="0.85" />
            <Setter Property="RenderTransform" Value="scale(1.0)" />
        </Style>
        <Style Selector="ToggleButton.filterBtn:checked">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="scale(1.0)" />
        </Style>

        <!-- Person card hover effect -->
        <Style Selector="Panel.personCard">
            <Setter Property="RenderTransform" Value="scale(1)" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Panel.personCard:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.06)" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <DataTemplate x:Key="FilterIconTemplate" x:DataType="vm:FilterItemBase">
            <ToggleButton Classes="filterBtn" IsChecked="{Binding IsSelected}">
                <Image
                    Width="30"
                    Height="30"
                    Source="{Binding Icon}" />
            </ToggleButton>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="WrapPanelTemplate">
            <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal" />
        </ItemsPanelTemplate>
    </UserControl.Resources>

    <Grid Name="LayoutRoot" ColumnDefinitions="*,0,0">
        <Grid Grid.Column="0" RowDefinitions="Auto,*">
        <!-- Filter Area -->
        <Border
            Grid.Row="0"
            Margin="8,8,8,4"
            Padding="10,8"
            Background="{DynamicResource SemiGrey1Color}"
            BorderBrush="{DynamicResource SemiGrey3Color}"
            BorderThickness="1"
            CornerRadius="10">
            <StackPanel Spacing="6">
                <!-- Search & Version & Filter toggle row -->
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <ToggleButton
                        Grid.Column="0"
                        Width="32" Height="32"
                        Margin="0,0,6,0"
                        Padding="4"
                        CornerRadius="6"
                        IsChecked="{Binding ShowFilters}"
                        ToolTip.Tip="显示/隐藏筛选器">
                        <PathIcon
                            Width="16" Height="16"
                            Data="{StaticResource SemiIconFilter}" />
                    </ToggleButton>
                    <TextBox
                        Grid.Column="1"
                        Name="SearchBar"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Classes="ClearButton"
                        Text="{Binding SearchText}"
                        Watermark="搜索角色名称..." />
                    <ComboBox
                        Grid.Column="2"
                        MinWidth="90"
                        VerticalAlignment="Center"
                        Classes="ClearButton"
                        ItemsSource="{Binding Versions}"
                        PlaceholderText="版本"
                        SelectedItem="{Binding SelectedVersion}" />
                </Grid>

                <!-- Collapsible filter section with animation -->
                <Border
                    ClipToBounds="True"
                    Classes.collapsed="{Binding !ShowFilters}">
                    <Border.Styles>
                        <Style Selector="Border">
                            <Setter Property="MaxHeight" Value="500" />
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="Transitions">
                                <Transitions>
                                    <DoubleTransition Property="MaxHeight" Duration="0:0:0.25" Easing="CubicEaseOut" />
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                                </Transitions>
                            </Setter>
                        </Style>
                        <Style Selector="Border.collapsed">
                            <Setter Property="MaxHeight" Value="0" />
                            <Setter Property="Opacity" Value="0" />
                        </Style>
                    </Border.Styles>
                    <StackPanel Spacing="6" Margin="0,2">
                        <!-- Weapon filters -->
                        <ItemsControl
                            ItemTemplate="{StaticResource FilterIconTemplate}"
                            ItemsPanel="{StaticResource WrapPanelTemplate}"
                            ItemsSource="{Binding WeaponFilters}" />
                        <!-- Move filters -->
                        <ItemsControl
                            ItemTemplate="{StaticResource FilterIconTemplate}"
                            ItemsPanel="{StaticResource WrapPanelTemplate}"
                            ItemsSource="{Binding MoveFilters}" />
                        <!-- Special filters -->
                        <ItemsControl
                            ItemTemplate="{StaticResource FilterIconTemplate}"
                            ItemsPanel="{StaticResource WrapPanelTemplate}"
                            ItemsSource="{Binding SpecialFilters}" />
                    </StackPanel>
                </Border>

                <!-- Result count & name toggle -->
                <Grid ColumnDefinitions="*,Auto,*">
                    <TextBlock
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        HorizontalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource SemiGrey6Color}"
                        Text="{Binding ResultCountText}" />
                    <CheckBox
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="名称"
                        FontSize="11"
                        IsChecked="{Binding ShowNames}"
                        Padding="4,0"
                        MinHeight="0" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Person Grid - custom VirtualizingWrapPanel -->
        <ScrollViewer
            Grid.Row="1"
            Margin="8,0,8,8"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <controls:VirtualizingWrapPanel
                Name="PersonGrid"
                Margin="0,4"
                ItemHeight="{Binding CardItemHeight}"
                ItemWidth="{Binding CardItemWidth}"
                Spacing="2"
                ItemsSource="{Binding FilteredPersons}">
                <controls:VirtualizingWrapPanel.ItemTemplate>
                    <DataTemplate x:DataType="vm:PersonViewModel">
                        <Panel Classes="personCard" Tapped="OnPersonCardTapped" DoubleTapped="OnPersonCardDoubleTapped">
                            <Panel.ContextMenu>
                                <ContextMenu>
                                    <MenuItem
                                        Command="{Binding #PersonSelectorDialog.((vm:PersonSelectorViewModel)DataContext).ShowSameCharactersCommand}"
                                        CommandParameter="{Binding}"
                                        Header="显示同角色" />
                                    <MenuItem
                                        Command="{Binding #PersonSelectorDialog.((vm:PersonSelectorViewModel)DataContext).ExportCommand}"
                                        CommandParameter="{Binding}"
                                        Header="导出" />
                                    <MenuItem
                                        Command="{Binding #PersonSelectorDialog.((vm:PersonSelectorViewModel)DataContext).DeleteCommand}"
                                        CommandParameter="{Binding}"
                                        Header="删除角色" />
                                </ContextMenu>
                            </Panel.ContextMenu>

                            <Grid RowDefinitions="Auto, Auto">
                                <!-- Face portrait with FaceFrame -->
                                <Panel
                                    Grid.Row="0"
                                    Width="64"
                                    Height="64"
                                    Margin="0,2,0,0"
                                    HorizontalAlignment="Center">
                                    <!-- Layer 1: FaceFrame background -->
                                    <Image Source="/Assets/UI/FaceFrame_BG.png" Stretch="Fill" />
                                    <!-- Layer 2: Character face -->
                                    <Image
                                        Margin="6"
                                        Source="{Binding Face^}"
                                        Stretch="UniformToFill" />
                                    <!-- Layer 3: FaceFrame overlay border -->
                                    <Image Source="/Assets/UI/FaceFrame.png" Stretch="Fill" />

                                    <!-- Weapon/Move icons at bottom-left of frame -->
                                    <StackPanel
                                        Margin="0,0,0,-2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Orientation="Horizontal">
                                        <Image
                                            Width="16"
                                            Height="16"
                                            Source="{Binding WeaponIcon}" />
                                        <Image
                                            Width="16"
                                            Height="16"
                                            Source="{Binding MoveIcon}" />
                                    </StackPanel>
                                    <!-- Trait icons at bottom-right of frame -->
                                    <ItemsControl
                                        Margin="0,0,0,-2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        ItemsSource="{Binding TraitIcons}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Image
                                                    Width="16"
                                                    Height="16"
                                                    Source="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </Panel>

                                <!-- Name (toggleable) -->
                                <TextBlock
                                    Grid.Row="1"
                                    Margin="2,1,2,0"
                                    HorizontalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    IsVisible="{Binding #PersonSelectorDialog.((vm:PersonSelectorViewModel)DataContext).ShowNames}"
                                    MaxLines="2"
                                    Text="{Binding Name}"
                                    TextAlignment="Center"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="Wrap" />
                                <!-- ToolTip on face when name hidden -->
                                <ToolTip.Tip>
                                    <TextBlock Text="{Binding Name}" />
                                </ToolTip.Tip>
                            </Grid>

                            <!-- Selection overlay -->
                            <Border
                                BorderThickness="2.5"
                                CornerRadius="4"
                                IsHitTestVisible="False"
                                IsVisible="{Binding IsSelected}">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                        <GradientStop Offset="0" Color="#4A90D9" />
                                        <GradientStop Offset="1" Color="#63B3ED" />
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                            </Border>
                        </Panel>
                    </DataTemplate>
                </controls:VirtualizingWrapPanel.ItemTemplate>
            </controls:VirtualizingWrapPanel>
        </ScrollViewer>
        </Grid>

        <GridSplitter
            Grid.Column="1"
            IsVisible="{Binding !#PersonSelectorDialog.IsSelectionMode}"
            ResizeDirection="Columns" />

        <Grid
            Grid.Column="2"
            Margin="12,8,12,10"
            IsVisible="{Binding !#PersonSelectorDialog.IsSelectionMode}"
            RowDefinitions="Auto,*">
            <Grid Margin="0,0,0,10" ColumnDefinitions="*,Auto">
                <ContentControl Content="{Binding SelectedPerson}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:PersonViewModel">
                            <Grid ColumnDefinitions="Auto,12,*">
                                <Panel Width="80" Height="80">
                                    <Image Source="/Assets/UI/FaceFrame_BG.png" Stretch="Fill" />
                                    <Image Margin="7" Source="{Binding Face^}" Stretch="UniformToFill" />
                                    <Image Source="/Assets/UI/FaceFrame.png" Stretch="Fill" />
                                </Panel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="3">
                                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                                    <TextBlock FontSize="13" Opacity="0.75" Text="{Binding Title}" TextWrapping="Wrap" />
                                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" Spacing="5">
                                            <Image Width="24" Height="24" Source="{Binding WeaponIcon}" ToolTip.Tip="{Binding WeaponTypeName}" />
                                            <Image Width="24" Height="24" Source="{Binding MoveIcon}" ToolTip.Tip="{Binding MoveTypeName}" />
                                            <ItemsControl MaxWidth="120" ItemsSource="{Binding OriginIcons}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel HorizontalAlignment="Right" Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:PersonOriginIconViewModel">
                                                        <Image Width="30" Height="24" Margin="1,0" Source="{Binding Icon}" Stretch="Uniform" ToolTip.Tip="{Binding Name}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
                <StackPanel Grid.Column="1" VerticalAlignment="Top" Orientation="Horizontal" Spacing="8">
                    <u:IconButton
                        Command="{Binding PersonDetails.SaveToGameCommand}"
                        Content="保存"
                        Icon="{StaticResource SemiIconSave}"
                        IsEnabled="{Binding !PersonDetails.IsSaving}"
                        IsVisible="{Binding IsEditMode}" />
                    <u:IconButton
                        Command="{Binding TogglePersonModeCommand}"
                        Content="{Binding PersonModeButtonText}"
                        Icon="{StaticResource SemiIconEdit}"
                        IsEnabled="{Binding IsPersonSelected}" />
                </StackPanel>
            </Grid>

            <views:PersonBrowserDetailsView
                Grid.Row="1"
                IsVisible="{Binding IsBrowseMode}" />

            <ScrollViewer
                Grid.Row="1"
                HorizontalScrollBarVisibility="Disabled"
                IsVisible="{Binding IsEditMode}">
                <ContentControl Content="{Binding PersonDetails}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate x:DataType="tools:PersonEditorViewModel">
                                <StackPanel Spacing="6">
                                    <Expander Header="基础信息" IsExpanded="False">
                                        <Grid
                                            Margin="10"
                                            ColumnDefinitions="*,12,*"
                                            RowDefinitions="Auto,10,Auto,10,Auto"
                                            IsEnabled="{Binding #PersonSelectorDialog.((vm:PersonSelectorViewModel)DataContext).IsEditMode}">
                                            <StackPanel>
                                                <TextBlock Opacity="0.65" Text="ID" />
                                                <TextBox Text="{Binding Id}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Opacity="0.65" Text="Roman" />
                                                <TextBox Text="{Binding Roman}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2">
                                                <TextBlock Opacity="0.65" Text="名称" />
                                                <TextBox Text="{Binding NameText}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="2">
                                                <TextBlock Opacity="0.65" Text="称号" />
                                                <TextBox Text="{Binding TitleText}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="4">
                                                <TextBlock Opacity="0.65" Text="Face" />
                                                <TextBox Text="{Binding Face}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="4" Grid.Column="2">
                                                <TextBlock Opacity="0.65" Text="Face 2" />
                                                <TextBox Text="{Binding Face2}" />
                                            </StackPanel>
                                        </Grid>
                                    </Expander>

                                    <Expander Header="战斗分类" IsExpanded="False">
                                        <Grid
                                            Margin="10"
                                            ColumnDefinitions="*,12,*"
                                            RowDefinitions="Auto,10,Auto,10,Auto"
                                            IsEnabled="{Binding #PersonSelectorDialog.((vm:PersonSelectorViewModel)DataContext).IsEditMode}">
                                            <StackPanel>
                                                <TextBlock Opacity="0.65" Text="武器类型" />
                                                <ComboBox ItemsSource="{Binding WeaponTypes}" SelectedItem="{Binding WeaponType}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Opacity="0.65" Text="移动类型" />
                                                <ComboBox ItemsSource="{Binding MoveTypes}" SelectedItem="{Binding MoveType}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2">
                                                <TextBlock Opacity="0.65" Text="魔法属性" />
                                                <ComboBox ItemsSource="{Binding Elements}" SelectedItem="{Binding TomeClass}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="2">
                                                <TextBlock Opacity="0.65" Text="作品 Origin" />
                                                <u:NumericUIntUpDown Value="{Binding Origin}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="14">
                                                <CheckBox Content="常规" IsChecked="{Binding RegularQ}" />
                                                <CheckBox Content="常驻" IsChecked="{Binding PermanentQ}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="4" Grid.Column="2">
                                                <TextBlock Opacity="0.65" Text="再动标记" />
                                                <u:NumericByteUpDown Value="{Binding RefresherQ}" />
                                            </StackPanel>
                                        </Grid>
                                    </Expander>

                                    <Expander Header="基础属性与成长" IsExpanded="False">
                                        <Grid
                                            Margin="10"
                                            ColumnDefinitions="*,*,*,*,*"
                                            RowDefinitions="Auto,8,Auto"
                                            IsEnabled="{Binding #PersonSelectorDialog.((vm:PersonSelectorViewModel)DataContext).IsEditMode}">
                                            <u:NumericIntUpDown Grid.Column="0" Margin="2" InnerLeftContent="HP" Value="{Binding Hp}" />
                                            <u:NumericIntUpDown Grid.Column="1" Margin="2" InnerLeftContent="攻击" Value="{Binding Atk}" />
                                            <u:NumericIntUpDown Grid.Column="2" Margin="2" InnerLeftContent="速度" Value="{Binding Spd}" />
                                            <u:NumericIntUpDown Grid.Column="3" Margin="2" InnerLeftContent="防守" Value="{Binding Def}" />
                                            <u:NumericIntUpDown Grid.Column="4" Margin="2" InnerLeftContent="魔防" Value="{Binding Res}" />
                                            <u:NumericIntUpDown Grid.Row="2" Grid.Column="0" Margin="2" InnerLeftContent="HP成长" Value="{Binding GrowHp}" />
                                            <u:NumericIntUpDown Grid.Row="2" Grid.Column="1" Margin="2" InnerLeftContent="攻成长" Value="{Binding GrowAtk}" />
                                            <u:NumericIntUpDown Grid.Row="2" Grid.Column="2" Margin="2" InnerLeftContent="速成长" Value="{Binding GrowSpd}" />
                                            <u:NumericIntUpDown Grid.Row="2" Grid.Column="3" Margin="2" InnerLeftContent="防成长" Value="{Binding GrowDef}" />
                                            <u:NumericIntUpDown Grid.Row="2" Grid.Column="4" Margin="2" InnerLeftContent="魔防成长" Value="{Binding GrowRes}" />
                                        </Grid>
                                    </Expander>

                                    <Expander Header="技能数组" IsExpanded="False">
                                        <ItemsControl
                                            Margin="10"
                                            ItemsSource="{Binding SkillsList}"
                                            IsEnabled="{Binding #PersonSelectorDialog.((vm:PersonSelectorViewModel)DataContext).IsEditMode}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="tools:StringWrapper">
                                                    <Grid Margin="0,3" ColumnDefinitions="90,*">
                                                        <TextBlock VerticalAlignment="Center" Opacity="0.65" Text="{Binding Label}" />
                                                        <TextBox Grid.Column="1" FontFamily="Consolas" Text="{Binding Value}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>

                                    <Expander Header="传说与特殊属性" IsExpanded="False">
                                        <StackPanel
                                            Margin="10"
                                            Spacing="10"
                                            IsEnabled="{Binding #PersonSelectorDialog.((vm:PersonSelectorViewModel)DataContext).IsEditMode}">
                                            <ToggleSwitch Content="启用传说/神阶数据" IsChecked="{Binding IsLegendary}" />
                                            <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,10,Auto,10,Auto">
                                                <StackPanel>
                                                    <TextBlock Opacity="0.65" Text="类型" />
                                                    <ComboBox ItemsSource="{Binding LegendaryKinds}" SelectedItem="{Binding LegendaryKind}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Opacity="0.65" Text="属性" />
                                                    <ComboBox ItemsSource="{Binding LegendaryElements}" SelectedItem="{Binding LegendaryElement}" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="2">
                                                    <TextBlock Opacity="0.65" Text="BST" />
                                                    <u:NumericByteUpDown Value="{Binding LegendaryBst}" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="2">
                                                    <TextBlock Opacity="0.65" Text="按钮技能 ID" />
                                                    <TextBox Text="{Binding LegendaryBtnSkillId}" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="14">
                                                    <CheckBox Content="Duel" IsChecked="{Binding LegendaryDuelQ}" />
                                                    <CheckBox Content="额外栏位" IsChecked="{Binding LegendaryAeExtraSlotQ}" />
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,*,*,*,*">
                                                <u:NumericIntUpDown Grid.Column="0" Margin="2" InnerLeftContent="HP" Value="{Binding LHp}" />
                                                <u:NumericIntUpDown Grid.Column="1" Margin="2" InnerLeftContent="攻击" Value="{Binding LAtk}" />
                                                <u:NumericIntUpDown Grid.Column="2" Margin="2" InnerLeftContent="速度" Value="{Binding LSpd}" />
                                                <u:NumericIntUpDown Grid.Column="3" Margin="2" InnerLeftContent="防守" Value="{Binding LDef}" />
                                                <u:NumericIntUpDown Grid.Column="4" Margin="2" InnerLeftContent="魔防" Value="{Binding LRes}" />
                                            </Grid>
                                        </StackPanel>
                                    </Expander>

                                    <Expander Header="内部数据" IsExpanded="False">
                                        <Grid
                                            Margin="10"
                                            ColumnDefinitions="*,12,*"
                                            RowDefinitions="Auto,10,Auto,10,Auto,10,Auto"
                                            IsEnabled="{Binding #PersonSelectorDialog.((vm:PersonSelectorViewModel)DataContext).IsEditMode}">
                                            <StackPanel>
                                                <TextBlock Opacity="0.65" Text="ID Num" />
                                                <u:NumericUIntUpDown Value="{Binding IdNum}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Opacity="0.65" Text="Version Num" />
                                                <u:NumericUIntUpDown Value="{Binding VersionNum}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2">
                                                <TextBlock Opacity="0.65" Text="Sort Value" />
                                                <u:NumericUIntUpDown Value="{Binding SortValue}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="2">
                                                <TextBlock Opacity="0.65" Text="Series" />
                                                <u:NumericByteUpDown Value="{Binding Series}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="4">
                                                <TextBlock Opacity="0.65" Text="Base Vector" />
                                                <u:NumericByteUpDown Value="{Binding BaseVector}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="4" Grid.Column="2">
                                                <TextBlock Opacity="0.65" Text="Dragonflower Num" />
                                                <u:NumericUIntUpDown Value="{Binding DragonflowerNum}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="6" Grid.ColumnSpan="3">
                                                <TextBlock Opacity="0.65" Text="Timestamp" />
                                                <TextBox Text="{Binding Timestamp}" />
                                            </StackPanel>
                                        </Grid>
                                    </Expander>
                                </StackPanel>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                </ContentControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
