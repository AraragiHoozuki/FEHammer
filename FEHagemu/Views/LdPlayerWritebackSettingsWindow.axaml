<Window
    x:Class="FEHagemu.Views.LdPlayerWritebackSettingsWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:vm="using:FEHagemu.ViewModels"
    Title="LDPlayer 写回设置"
    Width="620"
    Height="350"
    CanResize="False"
    Icon="/Assets/favicon.ico"
    WindowStartupLocation="CenterOwner"
    x:DataType="vm:LdPlayerWritebackSettingsViewModel"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border
            Padding="22,17"
            Background="{DynamicResource SemiColorBackground0}"
            BorderBrush="{DynamicResource SemiColorBorder}"
            BorderThickness="0,0,0,1">
            <StackPanel Spacing="3">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="LDPlayer 写回设置" />
                <TextBlock
                    FontSize="12"
                    Foreground="{DynamicResource SemiColorText2}"
                    Text="{Binding CurrentStatus}"
                    TextTrimming="CharacterEllipsis"
                    ToolTip.Tip="{Binding CurrentStatus}" />
            </StackPanel>
        </Border>

        <Grid
            Grid.Row="1"
            Margin="22,18"
            ColumnDefinitions="120,*,Auto"
            RowDefinitions="Auto,Auto,Auto,Auto">
            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="控制台程序" />
            <TextBox
                Grid.Column="1"
                MinWidth="330"
                IsEnabled="{Binding !AutoDetectConsole}"
                Text="{Binding ConsolePath, Mode=TwoWay}"
                Watermark="ldconsole.exe 或 dnconsole.exe" />
            <Button
                Grid.Column="2"
                Margin="8,0,0,0"
                Click="BrowseConsoleButton_OnClick"
                Content="浏览..."
                IsEnabled="{Binding !AutoDetectConsole}" />
            <CheckBox
                Grid.Row="1"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Margin="0,8,0,0"
                Content="自动检测控制台程序"
                IsChecked="{Binding AutoDetectConsole, Mode=TwoWay}" />

            <TextBlock Grid.Row="2" Margin="0,18,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="实例编号" />
            <u:NumericIntUpDown
                Grid.Row="2"
                Grid.Column="1"
                Width="130"
                Margin="0,18,0,0"
                HorizontalAlignment="Left"
                IsEnabled="{Binding !AutoDetectInstance}"
                Value="{Binding InstanceIndex, Mode=TwoWay}" />
            <CheckBox
                Grid.Row="3"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Margin="0,8,0,0"
                Content="从 VMDK 路径自动检测实例编号"
                IsChecked="{Binding AutoDetectInstance, Mode=TwoWay}" />
        </Grid>

        <Border
            Grid.Row="2"
            Padding="14,10"
            BorderBrush="{DynamicResource SemiColorBorder}"
            BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                <Button MinWidth="86" Click="CancelButton_OnClick" Content="取消" />
                <Button MinWidth="118" Click="SaveButton_OnClick" Content="保存并重新检测" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
